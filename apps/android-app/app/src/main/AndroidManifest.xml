<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required for sync-service / cloud-relay calls -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Health Connect: read-only sleep + steps, on-device (local-first) -->
    <uses-permission android:name="android.permission.health.READ_SLEEP" />
    <uses-permission android:name="android.permission.health.READ_STEPS" />

    <!-- Increment #12 (privacy hardening): cleartext traffic is disabled globally/in
         release builds. Any cleartext exception (local LAN dev against the on-prem
         sync-service) is granted only via a debug-build-only manifest + network
         security config override — see src/debug/AndroidManifest.xml and
         src/debug/res/xml/network_security_config_debug.xml. Do not flip this to
         true here or add a global network security config that permits cleartext. -->
    <application
        android:name=".JarvisApp"
        android:label="@string/app_name"
        android:theme="@style/Theme.Jarvis"
        android:allowBackup="false"
        android:supportsRtl="true"
        android:usesCleartextTraffic="false">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Increment E (bank push -> finance draft): reads notifications from a
             user-selected whitelist of bank apps, blocks OTP/2FA/authorization-code
             notifications outright, sanitizes the rest, then queues a FINANCE_ENTRY
             draft via the existing offline sync queue. The system enforces that only
             it can bind this service (android:permission below); the user must
             separately grant "Notification access" in system settings. -->
        <service
            android:name=".notifications.BankNotificationListenerService"
            android:label="@string/bank_notification_listener_label"
            android:exported="true"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>
    </application>
</manifest>
