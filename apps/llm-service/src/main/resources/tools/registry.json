[
  {
    "name": "create_todo",
    "description": "Create a new todo task for the user.",
    "input_schema": {
      "type": "object",
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "priority": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "URGENT"] },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title"]
    }
  },
  {
    "name": "update_todo",
    "description": "Update fields of an existing todo task.",
    "input_schema": {
      "type": "object",
      "properties": {
        "id": { "type": "integer" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "priority": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "URGENT"] },
        "status": { "type": "string", "enum": ["TODO", "IN_PROGRESS", "DONE", "CANCELLED"] },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id"]
    }
  },
  {
    "name": "list_todos",
    "description": "List todo tasks by status or time window.",
    "input_schema": {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["TODO", "IN_PROGRESS", "DONE", "CANCELLED"] },
        "from": { "type": "string", "format": "date-time" },
        "to": { "type": "string", "format": "date-time" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": []
    }
  },
  {
    "name": "complete_todo",
    "description": "Mark a todo task as done.",
    "input_schema": {
      "type": "object",
      "properties": {
        "id": { "type": "integer" }
      },
      "required": ["id"]
    }
  },
  {
    "name": "create_event",
    "description": "Create a calendar event for the user.",
    "input_schema": {
      "type": "object",
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "allDay": { "type": "boolean" },
        "location": { "type": "string" },
        "timezone": { "type": "string" },
        "recurrenceRule": { "type": "string" },
        "recurrenceUntil": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "startTime", "endTime"]
    }
  },
  {
    "name": "move_event",
    "description": "Move an existing event to a new time.",
    "input_schema": {
      "type": "object",
      "properties": {
        "eventId": { "type": "integer" },
        "newStartTime": { "type": "string", "format": "date-time" },
        "newEndTime": { "type": "string", "format": "date-time" }
      },
      "required": ["eventId", "newStartTime", "newEndTime"]
    }
  },
  {
    "name": "list_events",
    "description": "List calendar events for a time window.",
    "input_schema": {
      "type": "object",
      "properties": {
        "from": { "type": "string", "format": "date-time" },
        "to": { "type": "string", "format": "date-time" }
      },
      "required": []
    }
  },
  {
    "name": "find_free_slot",
    "description": "Find the next available time slot in the calendar.",
    "input_schema": {
      "type": "object",
      "properties": {
        "from": { "type": "string", "format": "date-time" },
        "to": { "type": "string", "format": "date-time" },
        "durationMinutes": { "type": "integer", "minimum": 5 },
        "workHoursStart": { "type": "string" },
        "workHoursEnd": { "type": "string" }
      },
      "required": ["from", "to", "durationMinutes"]
    }
  },
  {
    "name": "list_transactions",
    "description": "List finance transactions (read-only).",
    "input_schema": {
      "type": "object",
      "properties": {
        "from": { "type": "string", "format": "date-time" },
        "to": { "type": "string", "format": "date-time" },
        "category": { "type": "string" },
        "type": { "type": "string", "enum": ["EXPENSE", "INCOME"] }
      },
      "required": []
    }
  },
  {
    "name": "summarize_month",
    "description": "Summarize finance activity for a month (read-only).",
    "input_schema": {
      "type": "object",
      "properties": {
        "month": { "type": "string", "pattern": "^\\d{4}-\\d{2}$" }
      },
      "required": ["month"]
    }
  },
  {
    "name": "analyze_spending",
    "description": "Analyze spending by category or merchant (read-only).",
    "input_schema": {
      "type": "object",
      "properties": {
        "from": { "type": "string", "format": "date-time" },
        "to": { "type": "string", "format": "date-time" },
        "groupBy": { "type": "string", "enum": ["CATEGORY", "MERCHANT"] }
      },
      "required": ["from", "to"]
    }
  },
  {
    "name": "budget_status",
    "description": "Return budget status for the month (read-only).",
    "input_schema": {
      "type": "object",
      "properties": {
        "month": { "type": "string", "pattern": "^\\d{4}-\\d{2}$" }
      },
      "required": ["month"]
    }
  },
  {
    "name": "search_memory",
    "description": "Search long-term memory context (read-only).",
    "input_schema": {
      "type": "object",
      "properties": {
        "query": { "type": "string", "minLength": 1 },
        "topK": { "type": "integer", "minimum": 1, "maximum": 20 },
        "maxTokens": { "type": "integer", "minimum": 100, "maximum": 2000 }
      },
      "required": ["query"]
    }
  }
]
