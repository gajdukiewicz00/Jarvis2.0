<?xml version="1.0" encoding="UTF-8"?>
<!--
    security-service does not depend on jarvis-common, so it has its own
    logback-spring.xml with the same observability profile switching.
-->
<configuration>
    <property name="PLAIN_PATTERN"
              value="%d{ISO8601} [%thread] %-5level [traceId=%X{traceId:-}] [spanId=%X{spanId:-}] %logger{36} - %msg%n"/>

    <appender name="CONSOLE_PLAIN" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${PLAIN_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>spanId</includeMdcKeyName>
            <timeZone>UTC</timeZone>
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</timestampPattern>
        </encoder>
    </appender>

    <springProfile name="observability">
        <root level="INFO">
            <appender-ref ref="CONSOLE_JSON"/>
        </root>
    </springProfile>

    <springProfile name="!observability">
        <root level="INFO">
            <appender-ref ref="CONSOLE_PLAIN"/>
        </root>
    </springProfile>
</configuration>
