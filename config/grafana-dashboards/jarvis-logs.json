  "panels": [
    {
      "title": "Recent Jarvis Logs",
      "type": "logs",
      "gridPos": {
        "h": 16,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "{namespace=\"jarvis\",job=\"jarvis/pods\"}",
