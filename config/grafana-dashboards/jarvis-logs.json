        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      }
    },
    {
      "title": "Warnings / Errors",
      "type": "logs",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "{namespace=\"jarvis\",job=\"jarvis/pods\"} |~ \"(?i)(warn|error|exception)\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      }
    }
