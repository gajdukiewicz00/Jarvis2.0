{
  "vhosts": [
    {"name": "jarvis"}
  ],
  "permissions": [
    {
      "user": "jarvis",
      "vhost": "jarvis",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    }
  ],
  "exchanges": [
    {
      "name": "jarvis.commands",
      "vhost": "jarvis",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "jarvis.rpc",
      "vhost": "jarvis",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "jarvis.events",
      "vhost": "jarvis",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "jarvis.dlx",
      "vhost": "jarvis",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "queues": [
    {
      "name": "pc-control.commands",
      "vhost": "jarvis",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "jarvis.dlx",
        "x-dead-letter-routing-key": "dlq.pc-control"
      }
    },
    {
      "name": "smart-home.commands",
      "vhost": "jarvis",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "jarvis.dlx",
        "x-dead-letter-routing-key": "dlq.smart-home"
      }
    },
    {
      "name": "voice.commands",
      "vhost": "jarvis",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "jarvis.dlx",
        "x-dead-letter-routing-key": "dlq.voice"
      }
    },
    {
      "name": "assistant-core.commands",
      "vhost": "jarvis",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "jarvis.dlx",
        "x-dead-letter-routing-key": "dlq.assistant"
      }
    },
    {
      "name": "dlq.pc-control",
      "vhost": "jarvis",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "dlq.smart-home",
      "vhost": "jarvis",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "dlq.voice",
      "vhost": "jarvis",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "dlq.assistant",
      "vhost": "jarvis",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "bindings": [
    {
      "source": "jarvis.commands",
      "vhost": "jarvis",
      "destination": "pc-control.commands",
      "destination_type": "queue",
      "routing_key": "pc.control.#",
      "arguments": {}
    },
    {
      "source": "jarvis.commands",
      "vhost": "jarvis",
      "destination": "smart-home.commands",
      "destination_type": "queue",
      "routing_key": "smarthome.#",
      "arguments": {}
    },
    {
      "source": "jarvis.commands",
      "vhost": "jarvis",
      "destination": "voice.commands",
      "destination_type": "queue",
      "routing_key": "voice.#",
      "arguments": {}
    },
    {
      "source": "jarvis.commands",
      "vhost": "jarvis",
      "destination": "assistant-core.commands",
      "destination_type": "queue",
      "routing_key": "assistant.#",
      "arguments": {}
    },
    {
      "source": "jarvis.dlx",
      "vhost": "jarvis",
      "destination": "dlq.pc-control",
      "destination_type": "queue",
      "routing_key": "dlq.pc-control",
      "arguments": {}
    },
    {
      "source": "jarvis.dlx",
      "vhost": "jarvis",
      "destination": "dlq.smart-home",
      "destination_type": "queue",
      "routing_key": "dlq.smart-home",
      "arguments": {}
    },
    {
      "source": "jarvis.dlx",
      "vhost": "jarvis",
      "destination": "dlq.voice",
      "destination_type": "queue",
      "routing_key": "dlq.voice",
      "arguments": {}
    },
    {
      "source": "jarvis.dlx",
      "vhost": "jarvis",
      "destination": "dlq.assistant",
      "destination_type": "queue",
      "routing_key": "dlq.assistant",
      "arguments": {}
    }
  ]
}

