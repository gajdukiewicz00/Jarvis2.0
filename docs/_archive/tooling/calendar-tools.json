[
  {
    "name": "create_event",
    "description": "Create a calendar event for the user.",
    "input_schema": {
      "type": "object",
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "allDay": { "type": "boolean" },
        "location": { "type": "string" },
        "timezone": { "type": "string" },
        "recurrenceRule": { "type": "string" },
        "recurrenceUntil": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "startTime", "endTime"]
    }
  },
  {
    "name": "move_event",
    "description": "Move an existing event to a new time.",
    "input_schema": {
      "type": "object",
      "properties": {
        "eventId": { "type": "integer" },
        "newStartTime": { "type": "string", "format": "date-time" },
        "newEndTime": { "type": "string", "format": "date-time" }
      },
      "required": ["eventId", "newStartTime", "newEndTime"]
    }
  },
  {
    "name": "list_events",
    "description": "List calendar events for a time window.",
    "input_schema": {
      "type": "object",
      "properties": {
        "from": { "type": "string", "format": "date-time" },
        "to": { "type": "string", "format": "date-time" }
      },
      "required": []
    }
  },
  {
    "name": "find_free_slot",
    "description": "Find the next available time slot in the calendar.",
    "input_schema": {
      "type": "object",
      "properties": {
        "from": { "type": "string", "format": "date-time" },
        "to": { "type": "string", "format": "date-time" },
        "durationMinutes": { "type": "integer", "minimum": 5 },
        "workHoursStart": { "type": "string" },
        "workHoursEnd": { "type": "string" }
      },
      "required": ["from", "to", "durationMinutes"]
    }
  }
]
