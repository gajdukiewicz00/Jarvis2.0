[
  {
    "name": "list_transactions",
    "description": "List finance transactions (read-only).",
    "input_schema": {
      "type": "object",
      "properties": {
        "from": { "type": "string", "format": "date-time" },
        "to": { "type": "string", "format": "date-time" },
        "category": { "type": "string" },
        "type": { "type": "string", "enum": ["EXPENSE", "INCOME"] }
      },
      "required": []
    }
  },
  {
    "name": "summarize_month",
    "description": "Summarize finance activity for a month (read-only).",
    "input_schema": {
      "type": "object",
      "properties": {
        "month": { "type": "string", "pattern": "^\\d{4}-\\d{2}$" }
      },
      "required": ["month"]
    }
  },
  {
    "name": "analyze_spending",
    "description": "Analyze spending by category or merchant (read-only).",
    "input_schema": {
      "type": "object",
      "properties": {
        "from": { "type": "string", "format": "date-time" },
        "to": { "type": "string", "format": "date-time" },
        "groupBy": { "type": "string", "enum": ["CATEGORY", "MERCHANT"] }
      },
      "required": ["from", "to"]
    }
  },
  {
    "name": "budget_status",
    "description": "Return budget status for the month (read-only).",
    "input_schema": {
      "type": "object",
      "properties": {
        "month": { "type": "string", "pattern": "^\\d{4}-\\d{2}$" }
      },
      "required": ["month"]
    }
  }
]
