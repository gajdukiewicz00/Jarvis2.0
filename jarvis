#!/usr/bin/env bash
# =============================================================================
# jarvis — unified CLI for the local Jarvis stack.
# =============================================================================
set -uo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
JARVIS_NS="${JARVIS_NS:-jarvis-prod}"

CMD="${1:-}"; shift || true

usage() {
  cat <<'USAGE'
Usage: ./jarvis <command> [args]

Commands:
  up                 Build images, import into k3s, deploy, wait, smoke check
  status             Show pods, deployments, node IP, and host brain/voice health
  health             Quick READY/DEGRADED/FAILED verdict for the stack
  doctor             Self-check: GPU, disk, k3s, node, deploys, endpoint, gateway, brain
  drift-check        Compare live deployment image tags vs infra/k8s/overlays/prod (canonical)
  reboot-verify      Read-only post-reboot verification chain (see docs/DEPLOYMENT_CANONICAL.md)
  smoke-e2e          Post-deploy smoke: login, LLM chat, memory, planner (PASS/FAIL)
  logs <svc> [n]     Tail n (default 80) log lines of a deployment
  backup [dir]       pg_dump the Postgres databases to a timestamped tarball
  restore <file>     Restore a Postgres dump (DESTRUCTIVE — asks to confirm)
  update [svc]       Rebuild + redeploy all services (or one)
  stop               Stop the stack
  obsidian <cmd>     Obsidian vault: note|daily|memory|task|idea|search|index|status
USAGE
}

log()  { echo -e "\033[0;36m[INFO]\033[0m $*"; }
warn() { echo -e "\033[1;33m[WARN]\033[0m $*"; }
err()  { echo -e "\033[0;31m[ERROR]\033[0m $*" >&2; }
ok()   { echo -e "\033[0;32m[ OK ]\033[0m $*"; }

# Resolve a kubectl that can reach the cluster (plain kubectl, else sudo k3s kubectl).
KCTL=""
resolve_kubectl() {
  if kubectl version >/dev/null 2>&1 && kubectl -n "$JARVIS_NS" get ns >/dev/null 2>&1; then
    KCTL="kubectl"
  elif sudo -n k3s kubectl version >/dev/null 2>&1; then
    KCTL="sudo k3s kubectl"
  elif command -v k3s >/dev/null 2>&1; then
    KCTL="sudo k3s kubectl"
  else
    KCTL="kubectl"
  fi
}
k() { $KCTL -n "$JARVIS_NS" "$@"; }

# --- up (legacy build+deploy path) -------------------------------------------
cmd_up() {
  KUBECONFIG_PATH="${KUBECONFIG:-${HOME}/.kube/k3s.yaml}"; export KUBECONFIG="$KUBECONFIG_PATH"
  command -v kubectl >/dev/null 2>&1 || { err "kubectl not found"; exit 1; }
  command -v k3s >/dev/null 2>&1 || { err "k3s not found in PATH"; exit 1; }
  sudo -n true 2>/dev/null || { err "Passwordless sudo required for k3s ctr import"; exit 1; }
  kubectl cluster-info >/dev/null 2>&1 || { err "k3s cluster-info failed"; exit 1; }
  log "Building and importing images..."
  JARVIS_ROLLOUT_RESTART_AFTER_IMPORT=false "${PROJECT_ROOT}/scripts/build-images.sh"
  log "Deploying manifests..."
  ENABLE_BUILD=false "${PROJECT_ROOT}/jarvis-launch.sh" >/dev/null
  # Re-apply happens above resets host-model-daemon Endpoints to the 192.0.2.1 placeholder.
  # Patch it back to the node IP so the in-cluster 14B brain is reachable (idempotent).
  log "Wiring host-model-daemon endpoint to node IP..."
  "${PROJECT_ROOT}/scripts/jarvis-host-endpoint-check.sh" --fix 2>&1 | sed 's/^/  /' || warn "host endpoint fix failed — run scripts/jarvis-host-endpoint-check.sh --fix"
  cmd_status
  ok "Jarvis up complete"
}

# Detect the current node's InternalIP (never hardcode an IP — it changes
# across networks/DHCP; see docs/DEPLOYMENT_CANONICAL.md).
detect_node_ip() {
  k get nodes -o jsonpath='{.items[0].status.addresses[?(@.type=="InternalIP")].address}' 2>/dev/null | awk '{print $1}'
}

# --- status ------------------------------------------------------------------
cmd_status() {
  resolve_kubectl
  log "Namespace: $JARVIS_NS  (kubectl: $KCTL)"
  k get deploy 2>/dev/null | awk 'NR==1||/[0-9]\/[0-9]/'
  echo ""
  local total_deploy notready_deploy
  total_deploy="$(k get deploy --no-headers 2>/dev/null | wc -l)"
  notready_deploy="$(k get deploy --no-headers 2>/dev/null | awk '{split($2,a,"/"); if (a[1]!=a[2]) print $1}')"
  if [ -z "$notready_deploy" ]; then
    echo "deployments Ready: ${total_deploy:-0}/${total_deploy:-0}"
  else
    echo "deployments NOT fully Ready: $(echo "$notready_deploy" | wc -l)/${total_deploy:-?} -> $(echo "$notready_deploy" | tr '\n' ' ')"
  fi
  local notready; notready="$(k get pods --no-headers 2>/dev/null | grep -vc ' Running ')"
  echo "pods not Running: ${notready:-?}"
  echo ""
  local node_ip; node_ip="$(detect_node_ip)"
  echo "node InternalIP: ${node_ip:-unknown}"
  local ep_ip; ep_ip="$(k get endpoints host-model-daemon -o jsonpath='{.subsets[0].addresses[0].ip}' 2>/dev/null)"
  if [ -n "$node_ip" ] && [ "$ep_ip" = "$node_ip" ]; then
    echo "host-model-daemon endpoint: OK ($ep_ip == node IP)"
  else
    echo "host-model-daemon endpoint: MISMATCH (endpoint=${ep_ip:-<empty>} node=${node_ip:-unknown})"
  fi
  echo ""
  echo "host brains:"
  printf '  LLM  :18080  '; curl -s -m4 -o /dev/null -w 'health=%{http_code}\n' http://127.0.0.1:18080/health 2>/dev/null || echo "down"
  printf '  TTS  :18090  '; curl -s -m4 -o /dev/null -w 'health=%{http_code}\n' http://127.0.0.1:18090/health 2>/dev/null || echo "down"
}

cmd_health() {
  resolve_kubectl
  local total ready notready
  total="$(k get deploy --no-headers 2>/dev/null | wc -l)"
  notready="$(k get pods --no-headers 2>/dev/null | grep -vc ' Running ')"
  local llm tts
  llm="$(curl -s -m4 -o /dev/null -w '%{http_code}' http://127.0.0.1:18080/health 2>/dev/null)"
  tts="$(curl -s -m4 -o /dev/null -w '%{http_code}' http://127.0.0.1:18090/health 2>/dev/null)"
  if [ "${notready:-1}" -eq 0 ] && [ "$llm" = "200" ]; then
    ok "READY  (deploys=$total, all pods Running, LLM=$llm TTS=$tts)"
  elif [ "${notready:-1}" -le 2 ]; then
    warn "DEGRADED  (not-Running=$notready, LLM=$llm TTS=$tts)"
  else
    err "FAILED  (not-Running=$notready, LLM=$llm)"
  fi
}

# --- doctor (self-check) -----------------------------------------------------
cmd_doctor() {
  resolve_kubectl
  echo "== Jarvis doctor =="
  if command -v nvidia-smi >/dev/null 2>&1; then
    nvidia-smi --query-gpu=name,memory.used,memory.free --format=csv,noheader 2>/dev/null | sed 's/^/  GPU: /' || warn "GPU query failed"
  else warn "no nvidia-smi (GPU brain unavailable)"; fi
  local freg; freg="$(df -h "$HOME" | awk 'NR==2{print $4" free ("$5" used)"}')"; echo "  Disk($HOME): $freg"

  # k3s systemd service — distinct from API reachability below; a unit can
  # report 'active' while the API server is crashed, and vice versa a unit
  # can be stopped while a stale kubeconfig still points elsewhere.
  if command -v systemctl >/dev/null 2>&1; then
    systemctl is-active --quiet k3s 2>/dev/null \
      && ok "k3s systemd service active" \
      || err "k3s systemd service NOT active (sudo systemctl start k3s)"
  else
    warn "systemctl not found — cannot confirm k3s service state"
  fi

  k get ns >/dev/null 2>&1 && ok "k3s reachable ($JARVIS_NS)" || err "k3s not reachable"

  # node reachable + Ready (InternalIP resolved dynamically — never hardcoded;
  # see docs/DEPLOYMENT_CANONICAL.md)
  local node_ip node_ready_count
  node_ip="$(detect_node_ip)"
  node_ready_count="$(k get nodes --no-headers 2>/dev/null | awk '$2 ~ /(^|,)Ready(,|$)/' | wc -l)"
  if [ -n "$node_ip" ] && [ "${node_ready_count:-0}" -ge 1 ]; then
    ok "node reachable and Ready (InternalIP=$node_ip)"
  else
    err "node not reachable/Ready"
  fi

  for p in 18080 18090; do
    local c; c="$(curl -s -m4 -o /dev/null -w '%{http_code}' http://127.0.0.1:$p/health 2>/dev/null)"
    [ "$c" = "200" ] && ok "host :$p health 200" || warn "host :$p health=$c"
  done
  local nr; nr="$(k get pods --no-headers 2>/dev/null | grep -v ' Running ' | wc -l)"
  [ "${nr:-1}" -eq 0 ] && ok "all pods Running" || { warn "$nr pods not Running:"; k get pods --no-headers 2>/dev/null | grep -v ' Running '; }

  # all Deployments Ready (readyReplicas == desired replicas), not just "no
  # crashing pods" — catches a Deployment stuck at 0/1 with no pod at all.
  local notready_deploy
  notready_deploy="$(k get deploy --no-headers 2>/dev/null | awk '{split($2,a,"/"); if (a[1]!=a[2]) print $1"="$2}')"
  if [ -z "$notready_deploy" ]; then
    ok "all deployments Ready"
  else
    err "deployments not fully Ready:"; echo "$notready_deploy" | sed 's/^/    /'
  fi

  # gateway health — dynamic node IP (never hardcoded 10.113.x.x)
  if [ -n "$node_ip" ]; then
    if curl -sk -m4 -H 'Host: api.jarvis.local' "https://$node_ip/actuator/health" 2>/dev/null | grep -q '"status":"UP"'; then
      ok "gateway /actuator/health UP (https://$node_ip)"
    else
      warn "gateway /actuator/health not UP (https://$node_ip; check /etc/hosts api.jarvis.local)"
    fi
  else
    warn "gateway health — skipped, node IP unknown"
  fi

  # host-model-daemon endpoint IP must equal the current node InternalIP
  # (catches the 192.0.2.1 placeholder reset -> 14B brain unreachable)
  local ep_ip; ep_ip="$(k get endpoints host-model-daemon -o jsonpath='{.subsets[0].addresses[0].ip}' 2>/dev/null)"
  if [ -n "$node_ip" ] && [ "$ep_ip" = "$node_ip" ]; then
    ok "host-model-daemon endpoint IP ($ep_ip) == node InternalIP"
  else
    err "host-model-daemon endpoint IP (${ep_ip:-<empty>}) != node InternalIP (${node_ip:-unknown})"
  fi
  if [ -x "$PROJECT_ROOT/scripts/jarvis-host-endpoint-check.sh" ]; then
    if "$PROJECT_ROOT/scripts/jarvis-host-endpoint-check.sh" >/tmp/jarvis-ep.$$ 2>&1; then
      ok "host-model-daemon endpoint wired ($(grep -oE 'cluster .*HTTP [0-9]+' /tmp/jarvis-ep.$$ | tail -1))"
    else
      err "host-model-daemon endpoint BROKEN — 14B brain unreachable. Fix: ./scripts/jarvis-host-endpoint-check.sh --fix"
      grep -E 'Endpoints IP|slice|cluster|⚠|PLACEHOLDER' /tmp/jarvis-ep.$$ | sed 's/^/    /'
    fi
    rm -f /tmp/jarvis-ep.$$
  fi
}

# --- logs --------------------------------------------------------------------
cmd_logs() {
  resolve_kubectl
  local svc="${1:-}"; local n="${2:-80}"
  [ -z "$svc" ] && { err "usage: jarvis logs <service> [lines]"; exit 1; }
  k logs "deploy/$svc" --tail="$n" 2>&1
}

# --- backup (pg_dump) --------------------------------------------------------
cmd_backup() {
  resolve_kubectl
  local dir="${1:-${PROJECT_ROOT}/backups}"; mkdir -p "$dir"
  local ts; ts="$(date +%Y%m%d-%H%M%S 2>/dev/null || echo backup)"
  local out="${dir}/jarvis-pg-${ts}.sql.gz"
  log "Dumping Postgres ($JARVIS_NS/postgres-0) -> $out"
  local pguser pgdb
  pguser="$(k exec postgres-0 -- printenv POSTGRES_USER 2>/dev/null || echo jarvis)"
  pgdb="$(k exec postgres-0 -- printenv POSTGRES_DB 2>/dev/null || echo jarvis_db)"
  if k exec postgres-0 -- pg_dump -U "$pguser" "$pgdb" 2>/dev/null | gzip > "$out"; then
    ok "backup written: $out ($(du -h "$out" | cut -f1))"
  else
    err "pg_dump failed (user=$pguser db=$pgdb). Set PGUSER/PGDB or check pod name."; rm -f "$out"; exit 1
  fi
}

# --- restore (DESTRUCTIVE) ---------------------------------------------------
cmd_restore() {
  resolve_kubectl
  local file="${1:-}"
  [ -f "$file" ] || { err "usage: jarvis restore <dump.sql.gz>"; exit 1; }
  warn "This OVERWRITES the live database in $JARVIS_NS. Type 'yes' to proceed:"
  read -r ans; [ "$ans" = "yes" ] || { log "aborted"; exit 0; }
  local pguser pgdb
  pguser="$(k exec postgres-0 -- printenv POSTGRES_USER 2>/dev/null || echo jarvis)"
  pgdb="$(k exec postgres-0 -- printenv POSTGRES_DB 2>/dev/null || echo jarvis_db)"
  gunzip -c "$file" | k exec -i postgres-0 -- psql -U "$pguser" "$pgdb" && ok "restore complete" || { err "restore failed"; exit 1; }
}

# --- update / stop -----------------------------------------------------------
cmd_update() {
  local svc="${1:-}"
  if [ -n "$svc" ]; then
    log "Rebuild+redeploy $svc"; "${PROJECT_ROOT}/scripts/build-images.sh" "$svc" 2>/dev/null || warn "build-images.sh did not accept a single arg"
    resolve_kubectl; k rollout restart "deploy/$svc"
  else
    log "Rebuild+redeploy all"; "${PROJECT_ROOT}/scripts/build-images.sh"
  fi
}

cmd_stop() {
  if [ -x "${PROJECT_ROOT}/scripts/product/jarvis-stop.sh" ]; then
    "${PROJECT_ROOT}/scripts/product/jarvis-stop.sh" "$@"
  else
    err "scripts/product/jarvis-stop.sh missing"
    exit 1
  fi
}

case "$CMD" in
  ""|-h|--help|help) usage ;;
  up)       cmd_up ;;
  status)   cmd_status ;;
  health)   cmd_health ;;
  doctor)   cmd_doctor ;;
  drift-check)    bash "$PROJECT_ROOT/scripts/jarvis-image-drift-check.sh" "$@" ;;
  reboot-verify)  bash "$PROJECT_ROOT/scripts/jarvis-post-reboot-verify.sh" "$@" ;;
  smoke-e2e)      bash "$PROJECT_ROOT/scripts/jarvis-smoke-e2e.sh" "$@" ;;
  logs)     cmd_logs "$@" ;;
  backup)   cmd_backup "$@" ;;
  restore)  cmd_restore "$@" ;;
  update)   cmd_update "$@" ;;
  stop)     cmd_stop "$@" ;;
  obsidian) python3 "$PROJECT_ROOT/scripts/jarvis-obsidian.py" "$@" ;;
  ask)      bash "$PROJECT_ROOT/scripts/jarvis-ask.sh" "$@" ;;
  desktop)  bash "$PROJECT_ROOT/scripts/jarvis-desktop.sh" "$@" ;;
  parse-bank) bash "$PROJECT_ROOT/scripts/jarvis-parse-bank.sh" "$@" ;;
  *) err "Unknown command: $CMD"; usage; exit 1 ;;
esac
