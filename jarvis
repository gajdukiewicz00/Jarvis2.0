#!/usr/bin/env bash
set -euo pipefail

CMD="${1:-}"
if [[ -z "$CMD" || "$CMD" == "-h" || "$CMD" == "--help" ]]; then
  cat <<'USAGE'
Usage: ./jarvis up

Commands:
  up    Build images, import into k3s, deploy manifests, wait for readiness, run smoke check
USAGE
  exit 0
fi

if [[ "$CMD" != "up" ]]; then
  echo "Unknown command: $CMD" >&2
  exit 1
fi

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
KUBECONFIG_PATH="${KUBECONFIG:-${HOME}/.kube/k3s.yaml}"
export KUBECONFIG="$KUBECONFIG_PATH"

log() { echo -e "\033[0;36m[INFO]\033[0m $*"; }
warn() { echo -e "\033[1;33m[WARN]\033[0m $*"; }
err() { echo -e "\033[0;31m[ERROR]\033[0m $*"; }

preflight() {
  command -v kubectl >/dev/null 2>&1 || { err "kubectl not found"; exit 1; }
  command -v k3s >/dev/null 2>&1 || { err "k3s not found in PATH"; exit 1; }
  if ! sudo -n true 2>/dev/null; then
    err "Passwordless sudo required for k3s ctr import. Configure /etc/sudoers.d/jarvis-automation"
    exit 1
  fi
  if ! kubectl cluster-info >/dev/null 2>&1; then
    err "k3s cluster-info failed for KUBECONFIG=$KUBECONFIG"
    exit 1
  fi
}

build_and_import() {
  log "Building and importing images into k3s..."
  JARVIS_ROLLOUT_RESTART_AFTER_IMPORT=false \
    "${PROJECT_ROOT}/scripts/build-images.sh"
}

deploy() {
  log "Deploying manifests (no rebuild)..."
  ENABLE_BUILD=false "${PROJECT_ROOT}/jarvis-launch.sh" >/dev/null
}

wait_ready() {
  log "Waiting for core services..."
  kubectl -n jarvis rollout status statefulset/postgres --timeout=180s
  kubectl -n jarvis rollout status deployment/security-service --timeout=180s
  kubectl -n jarvis rollout status deployment/api-gateway --timeout=180s
  kubectl -n jarvis rollout status deployment/orchestrator --timeout=180s
  kubectl -n jarvis rollout status deployment/life-tracker --timeout=180s
  kubectl -n jarvis rollout status deployment/analytics-service --timeout=180s
  kubectl -n jarvis rollout status deployment/planner-service --timeout=180s
  kubectl -n jarvis rollout status deployment/user-profile --timeout=180s
  kubectl -n jarvis rollout status deployment/nlp-service --timeout=180s
  kubectl -n jarvis rollout status deployment/pc-control --timeout=180s
  kubectl -n jarvis rollout status deployment/smart-home-service --timeout=180s
  kubectl -n jarvis rollout status deployment/voice-gateway --timeout=180s
}

smoke_check() {
  log "Smoke check: api-gateway /actuator/health"
  kubectl -n jarvis port-forward svc/api-gateway 8080:8080 >/dev/null 2>&1 &
  pf_pid=$!
  trap 'kill "$pf_pid" >/dev/null 2>&1 || true' EXIT
  sleep 2
  if ! curl -sS -m 5 http://localhost:8080/actuator/health | rg -q 'UP'; then
    warn "Health check failed or not UP"
    return 1
  fi
  log "Health check OK"
}

preflight
build_and_import
deploy
wait_ready
smoke_check
log "Jarvis up complete"
