{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "RED status",
      "type": "text",
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "**RED (Rate / Errors / Duration) dashboard for security-service.** All metrics below are REAL and already emitted by `SecurityMetrics.java`: `security_token_revocations_total{scope,reason}` (`scope` = `single|all`), `security_login_failures_total{reason}` (`reason` = `INVALID_CREDENTIALS|ACCOUNT_DISABLED`, from `AuthService`), and `security_audit_events_total{type}`, plus the standard Micrometer `http_server_requests_seconds_*` / `jvm_*` Actuator metrics. security-service has no dedicated Timer, so Duration below relies on HTTP latency only; `security_login_failures_total` is the real domain Errors signal (auth failures), distinct from HTTP 5xx."
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "title": "Service Health",
      "type": "stat",
      "description": "up{job=\"jarvis-actuator\", app=\"security-service\"} — 1 = UP, 0 = DOWN/not scraped",
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "expr": "max by (app) (up{job=\"jarvis-actuator\", app=\"security-service\"})",
          "legendFormat": "{{ app }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "horizontal"
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "title": "Login Failures, Last 1h",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "expr": "clamp_min(sum(increase(security_login_failures_total{application=\"security-service\"}[1h])), 0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "title": "RATE — HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "targets": [
        {
          "expr": "sum by (application) (rate(http_server_requests_seconds_count{job=\"jarvis-actuator\",application=\"security-service\"}[5m]))",
          "legendFormat": "{{ application }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "title": "RATE — Token Revocations & Audit Events",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "targets": [
        {
          "expr": "sum by (scope, reason) (rate(security_token_revocations_total{application=\"security-service\"}[5m]))",
          "legendFormat": "revocation {{ scope }}/{{ reason }}",
          "refId": "A"
        },
        {
          "expr": "sum by (type) (rate(security_audit_events_total{application=\"security-service\"}[5m]))",
          "legendFormat": "audit {{ type }}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "unit": "short"
        },
        "overrides": []
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "title": "ERRORS — HTTP 5xx Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 17
      },
      "targets": [
        {
          "expr": "sum by (application) (rate(http_server_requests_seconds_count{status=~\"5..\",job=\"jarvis-actuator\",application=\"security-service\"}[5m]))",
          "legendFormat": "{{ application }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "title": "ERRORS — Login Failures by Reason",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 17
      },
      "targets": [
        {
          "expr": "sum by (reason) (rate(security_login_failures_total{application=\"security-service\"}[5m]))",
          "legendFormat": "{{ reason }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20
          },
          "unit": "short"
        },
        "overrides": []
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "title": "DURATION — HTTP Latency Avg (5m)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 25
      },
      "targets": [
        {
          "expr": "sum by (application) (rate(http_server_requests_seconds_sum{job=\"jarvis-actuator\",application=\"security-service\"}[5m])) / clamp_min(sum by (application) (rate(http_server_requests_seconds_count{job=\"jarvis-actuator\",application=\"security-service\"}[5m])), 0.001)",
          "legendFormat": "{{ application }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "unit": "s"
        },
        "overrides": []
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "title": "DURATION — No Timer metric emitted",
      "type": "text",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 25
      },
      "options": {
        "mode": "markdown",
        "content": "security-service's `SecurityMetrics.java` registers only Counters (`security.token.revocations`, `security.login.failures`, `security.audit.events`) — no Timer. HTTP Latency Avg (left) is the RED duration signal for this service today."
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "title": "JVM Heap Usage (%)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 33
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\",job=\"jarvis-actuator\",application=\"security-service\"} / jvm_memory_max_bytes{area=\"heap\",job=\"jarvis-actuator\",application=\"security-service\"} * 100",
          "legendFormat": "{{ application }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "unit": "percent",
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "title": "JVM Threads",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 33
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=\"jarvis-actuator\",application=\"security-service\"}",
          "legendFormat": "{{ application }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5
          },
          "unit": "short"
        },
        "overrides": []
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "jarvis",
    "red",
    "security-service"
  ],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 2,
        "name": "DS_PROMETHEUS",
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Jarvis RED - Security Service",
  "uid": "jarvis-red-security-service"
}
