{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "title": "About this dashboard",
      "type": "text",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "Ad-hoc log views backing `observability/loki/wave1-log-queries.md`. Labels follow the current Alloy pipeline (`k8s/base/observability/alloy.yaml`): `namespace=\"jarvis-prod\"`, `job=\"jarvis-prod/pods\"`, `app=\"<service>\"`. Query text uses real log lines grepped from source where they exist; queries marked PROPOSED rely on framework exception class names that will appear once a real failure occurs, not on a confirmed existing log statement."
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "title": "Media job failures [media-service]",
      "type": "logs",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 3
      },
      "targets": [
        {
          "expr": "{namespace=\"jarvis-prod\", app=\"media-service\"} |~ `(?i)(media job .* failed|skipping unreadable media job)`",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      }
    },
    {
      "title": "Agent task stuck / failing (best-effort — see Prometheus backlog alert for the real signal) [agent-service]",
