# Jarvis 2.0 local secrets template
# Copy to ~/.jarvis/secrets/secrets.env and replace placeholder values locally.

# PostgreSQL
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=CHANGE-ME-GENERATE-WITH-openssl-rand-base64-32
SPRING_DATASOURCE_USERNAME=jarvis
SPRING_DATASOURCE_PASSWORD=CHANGE-ME-GENERATE-WITH-openssl-rand-base64-32
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres.jarvis.svc.cluster.local:5432/jarvis

# RabbitMQ / AMQP
RABBITMQ_DEFAULT_USER=jarvis
RABBITMQ_DEFAULT_PASS=CHANGE-ME-GENERATE-WITH-openssl-rand-base64-32
RABBITMQ_ERLANG_COOKIE=CHANGE-ME-GENERATE-WITH-openssl-rand-base64-32
SPRING_RABBITMQ_USERNAME=jarvis
SPRING_RABBITMQ_PASSWORD=CHANGE-ME-GENERATE-WITH-openssl-rand-base64-32

# MQTT
MQTT_USERNAME=jarvis_mqtt
MQTT_PASSWORD=CHANGE-ME-GENERATE-WITH-openssl-rand-base64-32

# JWT / internal service auth
JWT_SECRET=CHANGE-ME-GENERATE-WITH-openssl-rand-base64-32
SERVICE_JWT_SECRET=CHANGE-ME-GENERATE-WITH-openssl-rand-base64-32

# Optional encryption key
ENCRYPTION_KEY=CHANGE-ME-GENERATE-WITH-openssl-rand-base64-32

# Optional desktop wake-word access key
PORCUPINE_ACCESS_KEY=CHANGE-ME-PICOVOICE-ACCESS-KEY
