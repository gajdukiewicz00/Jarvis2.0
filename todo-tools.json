[
  {
    "name": "create_todo",
    "description": "Create a new todo task for the user.",
    "input_schema": {
      "type": "object",
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "priority": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "URGENT"] },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title"]
    }
  },
  {
    "name": "update_todo",
    "description": "Update fields of an existing todo task.",
    "input_schema": {
      "type": "object",
      "properties": {
        "id": { "type": "integer" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "priority": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "URGENT"] },
        "status": { "type": "string", "enum": ["TODO", "IN_PROGRESS", "DONE", "CANCELLED"] },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id"]
    }
  },
  {
    "name": "list_todos",
    "description": "List todo tasks by status or time window.",
    "input_schema": {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["TODO", "IN_PROGRESS", "DONE", "CANCELLED"] },
        "from": { "type": "string", "format": "date-time" },
        "to": { "type": "string", "format": "date-time" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": []
    }
  },
  {
    "name": "complete_todo",
    "description": "Mark a todo task as done.",
    "input_schema": {
      "type": "object",
      "properties": {
        "id": { "type": "integer" }
      },
      "required": ["id"]
    }
  }
]
